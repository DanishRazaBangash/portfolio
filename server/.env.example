NODE_ENV=production
PORT=5000

MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/portfolio

JWT_SECRET=your_super_secret_jwt_key_here

# In production this is the same as your Render URL
CLIENT_URL=https://your-app.onrender.com

# Email (Gmail — use an App Password, not your real password)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_TO=your@gmail.com

# Admin account for seeding (run: node config/seed.js)
ADMIN_EMAIL=admin@yourdomain.dev
ADMIN_PASSWORD=changeme123
